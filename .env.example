# SignalWire Personal Access Token, required to pull the FreeSWITCH packages
# from the SignalWire Debian repo at build time.
# https://developer.signalwire.com/freeswitch/FreeSWITCH-Explained/Installation/HOWTO-Create-a-SignalWire-Personal-Access-Token_67240087/
SIGNALWIRE_TOKEN=replace-me

# Where rmbd's REST API lives. With `network_mode: host` on Linux the
# container can reach the host directly; in a paired compose stack use the
# service name (e.g. http://rmbd:8080).
RMBD_URL=http://localhost:8080
